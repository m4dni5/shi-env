# Sway config — Shi (勢)
# Ported from i3. Sway is i3-compatible in config syntax; differences noted inline.

set $mod Mod4
font pango:monospace 10

# Floating — $mod + left-click drag to move, $mod + right-click drag to resize
floating_modifier $mod

# Colors — dark mountain twilight
set $bg       #1a1a2e
set $fg       #c8c8d4
set $accent   #c9a227
set $urgent   #c94427
set $dim      #4a4a5e

# Terminal
bindsym $mod+Return exec kitty
bindsym $mod+q kill
bindsym $mod+d exec --no-startup-id rofi -show drun -show-icons
bindsym $mod+Tab exec --no-startup-id ~/.config/sway/sway-window-switcher.sh
bindsym $mod+Shift+d exec --no-startup-id rofi -show run
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway?' -B 'Yes' 'swaymsg exit'

# Focus (Vi-style)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Splits
bindsym $mod+v split h
bindsym $mod+Shift+v split v

# Fullscreen
bindsym $mod+f fullscreen toggle

# Workspaces
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10

# Move to workspace
bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9
bindsym $mod+Shift+0 move container to workspace 10

# Layout
bindsym $mod+b layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Float
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Scratchpad
bindsym $mod+minus scratchpad show
bindsym $mod+Shift+minus move scratchpad

# Resize
mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt
    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt
    bindsym Shift+h resize shrink width 50 px or 50 ppt
    bindsym Shift+j resize grow height 50 px or 50 ppt
    bindsym Shift+k resize shrink height 50 px or 50 ppt
    bindsym Shift+l resize grow width 50 px or 50 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Window decorations
default_border pixel 2
default_floating_border pixel 2
title_align center

# Gaps (Sway has i3-gaps built in — no separate package needed)
gaps inner 4
gaps outer 0

# Bar — sway manages waybar lifecycle (restarts on crash)
bar {
    swaybar_command waybar
}

# Ensure Screenshots directory exists
exec --no-startup-id mkdir -p ~/Screenshots

# Wallpaper (replaces feh)
exec --no-startup-id swaybg -i ~/wallpapers/vestige-dark.png -m fill

# ydotold daemon (for ydotool input simulation)
exec --no-startup-id ydotoold

# Kitty (primary terminal)
exec --no-startup-id kitty &

# Chromium with CDP
exec --no-startup-id chromium --remote-debugging-port=9222 --no-first-run --no-default-browser-check &

# Agent TUI — Quake dropdown ($mod+grave to toggle)
exec --no-startup-id kitty \
  --class shi-tui \
  --title Shi \
  -o confirm_os_window_close=0 \
  -o background_opacity=0.92 \
  -e hermes --tui -c -s sway-desktop,tmux

for_window [app_id="shi-tui"] \
  floating enable, \
  move scratchpad, \
  border pixel 2

bindsym $mod+grave exec --no-startup-id ~/.config/sway/shi-toggle.sh

# Screenshots (grim + slurp)
bindsym Print exec --no-startup-id grim ~/Screenshots/shot-$(date +%Y%m%d-%H%M%S).png
bindsym $mod+Print exec --no-startup-id grim -g "$(slurp)" ~/Screenshots/shot-$(date +%Y%m%d-%H%M%S).png

# Opacity — sway handles this natively (no picom needed)
# Focused kitty at 90%, unfocused at 80% opacity
for_window [app_id="kitty"] opacity 0.9
# Chromium stays at 100% (default)
